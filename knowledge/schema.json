    "taf_inpatient_header": {
      "era": "TAF 2016-2018",
      "type": "inpatient",
      "years": [2016, 2017, 2018],
      "year_column": "RFRNC_YR",
      "patient_id_column": "PATIENT_ID",
      "_note": "TAF era uses UPPERCASE PATIENT_ID, RFRNC_YR instead of YR_NUM, BIRTH_DT instead of EL_DOB, DGNS_CD instead of DIAG_CD, and has 12 diagnosis columns",
      "columns": {
        "PATIENT_ID":   {"type": "varchar(40)", "note": "UPPERCASE — different from ERA1/2"},
        "BENE_ID":      {"type": "varchar(15)"},
        "STATE_CD":     {"type": "varchar(2)"},
        "STATE_KEY":    {"type": "int",    "note": "partition key — MUST filter (UPPERCASE)"},
        "RFRNC_YR":     {"type": "int",    "note": "year — MUST filter (replaces YR_NUM)"},
        "BIRTH_DT":     {"type": "date",   "note": "replaces EL_DOB; no sex/race columns in TAF claim tables"},
        "srvc_bgn_dt":  {"type": "date"},
        "srvc_end_dt":  {"type": "date"},
        "DGNS_CD_1":    {"type": "varchar(7)", "note": "TAF uses DGNS_CD not DIAG_CD"},
        "DGNS_CD_2":    {"type": "varchar(7)"},
        "DGNS_CD_3":    {"type": "varchar(7)"},
        "DGNS_CD_4":    {"type": "varchar(7)"},
        "DGNS_CD_5":    {"type": "varchar(7)"},
        "DGNS_CD_6":    {"type": "varchar(7)"},
        "DGNS_CD_7":    {"type": "varchar(7)"},
        "DGNS_CD_8":    {"type": "varchar(7)"},
        "DGNS_CD_9":    {"type": "varchar(7)"},
        "DGNS_CD_10":   {"type": "varchar(7)"},
        "DGNS_CD_11":   {"type": "varchar(7)"},
        "DGNS_CD_12":   {"type": "varchar(7)"}
      },
      "diag_columns": ["DGNS_CD_1","DGNS_CD_2","DGNS_CD_3","DGNS_CD_4","DGNS_CD_5","DGNS_CD_6","DGNS_CD_7","DGNS_CD_8","DGNS_CD_9","DGNS_CD_10","DGNS_CD_11","DGNS_CD_12"],
      "extraction_table": "Re_All_taf_inpatient_header",
      "extraction_procedure": "Re_All_taf_inpatient_header"
    },

    "taf_other_services_header": {
      "era": "TAF 2016-2018",
      "type": "outpatient",
      "years": [2016, 2017, 2018],
      "year_column": "RFRNC_YR",
      "patient_id_column": "PATIENT_ID",
      "columns": {
        "PATIENT_ID":   {"type": "varchar(40)"},
        "BENE_ID":      {"type": "varchar(15)"},
        "STATE_CD":     {"type": "varchar(2)"},
        "STATE_KEY":    {"type": "int",    "note": "partition key — MUST filter"},
        "RFRNC_YR":     {"type": "int",    "note": "year — MUST filter"},
        "BIRTH_DT":     {"type": "date"},
        "srvc_bgn_dt":  {"type": "date"},
