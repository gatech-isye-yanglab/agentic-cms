      "columns": ["patient_id","BENE_ID","STATE_CD","state_key","YR_NUM","EL_DOB","EL_SEX_CD","EL_RACE_ETHNCY_CD","srvc_bgn_dt","srvc_end_dt","DIAG_CD_1","DIAG_CD_2"]
    },
    "Re_All_other_services_header": {
      "created_by": "step1_extraction/Re_All_other_services_header.sql",
      "source": "cms_source.taf_other_services_header",
      "columns": ["PATIENT_ID","BENE_ID","STATE_CD","STATE_KEY","RFRNC_YR","BIRTH_DT","srvc_bgn_dt","srvc_end_dt","DGNS_CD_1","DGNS_CD_2"]
    },
    "Re_All_taf_inpatient_header": {
      "created_by": "step1_extraction/Re_All_taf_inpatient.sql",
      "source": "cms_source.taf_inpatient_header",
      "columns": ["PATIENT_ID","BENE_ID","STATE_CD","STATE_KEY","RFRNC_YR","BIRTH_DT","srvc_bgn_dt","srvc_end_dt","DGNS_CD_1..12"]
    },
    "all_combine": {
      "created_by": "step2_combine/combined_inpatient.sql",
      "sources": ["Re_all_inpatient","Re_all_inpatient1315","Re_all_other_therapy","Re_all_other_therapy1315","Re_All_other_services_header","Re_All_taf_inpatient_header"],
      "columns": {
        "PATIENT_ID": "varchar(40)",
        "BENE_ID":    "varchar(15)",
        "STATE_CD":   "varchar(2)",
        "STATE_KEY":  "int",
        "YR_NUM":     "int — TAF RFRNC_YR mapped here",
        "BIRTH_DT":   "date — ERA1/2 EL_DOB mapped here",
        "srvc_bgn_dt":"date",
        "srvc_end_dt":"date",
        "DIAG_CD_1..12": "varchar(8/7) — ERA1/2 DIAG_CD mapped, TAF DGNS_CD mapped"
      },
      "_note": "Drops EL_SEX_CD and EL_RACE_ETHNCY_CD — these are not recoverable downstream"
    },
    "All_Selected_state": {
      "created_by": "step3_filter/all_selected_state.sql",
      "source": "all_combine",
      "filter": "STATE_CD IN ('AL','FL','GA','MS','NC','SC','TN')",
      "columns": "same as all_combine"
    },
    "test_temp_all_in_two_years_GA": {
      "created_by": "step4_two_year/Loop_all_in_two_years.sql",
      "source": "All_Selected_state",
      "filter": "STATE_CD = 'GA' only (CURRENT LIMITATION — not all 7 states)",
      "columns": {
        "patient_id": "varchar(40)",
        "srvc_bgn_DT": "date",
        "appears_within_2_years": "tinyint — 1 if patient has another claim within 730 days"
      },
      "logic": "For each patient-visit, check if there exists a later visit within 2 years (DATEDIFF <= 730)"
    },
    "final_patient": {
      "created_by": "step5_consolidate/step_5.sql",
      "sources": ["lung_inpatient_records (inpatient)", "lung_patient_records (outpatient)"],
      "_gap": "lung_inpatient_records and lung_patient_records are undocumented bridge tables not created by this pipeline",
      "columns": {
        "patient_id": "varchar(40)",
        "sex_cd":     "varchar — 'ambiguous' if conflicting across records",
        "race_cd":    "varchar — 'ambiguous' if conflicting",
        "bgn_dt":     "date — min srvc_bgn_dt; '1000-01-01' if ambiguous",
        "end_dt":     "date — max srvc_end_dt; '1000-01-01' if ambiguous",
        "state_key":  "int or 'ambiguous'",
        "diag_cd_list": "comma-separated concatenation of all diagnosis codes"
      }
    }
  },

  "reference_tables": {
    "icd_9_cm": {
      "columns": {"codes": "varchar(40)"},
      "purpose": "ICD-9 diabetes diagnosis codes used in WHERE IN filter"
    },
    "ICD code": {
      "_note": "Table name has a space — must be backtick-quoted: `ICD code`",
      "columns": {
        "ICD10_code": "varchar",
        "ICD9_Code": "varchar"
      },
      "purpose": "ICD-10 to ICD-9 mapping for cross-era code lookup"
    },
    "HCPCS_Codes": {
      "columns": {"HCPCS_codes": "varchar"},
      "purpose": "Diabetes-related HCPCS procedure codes"
    },
    "state_codes": {
      "columns": {
        "state_key": "int",
        "state_code": "varchar(2)"
      },
      "purpose": "Cursor iteration — cross-join with data_years drives the extraction loops"
    },
    "data_years": {
      "columns": {"year_num": "int"},
      "purpose": "Cursor iteration — provides year values for the extraction loop"
    }
  },

  "pipeline_steps": [
    {"step": 1, "folder": "reference/",          "output": ["icd_9_cm","ICD code","HCPCS_Codes"]},
    {"step": 2, "folder": "step1_extraction/",   "output": ["Re_all_inpatient","Re_all_inpatient1315","Re_all_other_therapy","Re_all_other_therapy1315","Re_All_other_services_header","Re_All_taf_inpatient_header"]},
    {"step": 3, "folder": "step2_combine/",      "output": ["all_combine"]},
    {"step": 4, "folder": "step3_filter/",       "output": ["All_Selected_state"]},
    {"step": 5, "folder": "step4_two_year/",     "output": ["test_temp_all_in_two_years_GA"], "note": "GA only"},
    {"step": 6, "folder": "step5_consolidate/",  "output": ["single_row_inpatient","single_row_outpatient","union_patient","single_row_all_patient","ambiguous_*","final_patient"]}
  ]
