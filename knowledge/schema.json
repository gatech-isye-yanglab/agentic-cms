        "EL_SEX_CD":           {"type": "varchar(1)"},
        "EL_RACE_ETHNCY_CD":   {"type": "varchar(1)"},
        "srvc_bgn_dt":         {"type": "date"},
        "srvc_end_dt":         {"type": "date"},
        "DIAG_CD_1":           {"type": "varchar(8)", "note": "ICD-9 or ICD-10 diagnosis code"},
        "DIAG_CD_2":           {"type": "varchar(8)"},
        "DIAG_CD_3":           {"type": "varchar(8)"},
        "DIAG_CD_4":           {"type": "varchar(8)"},
        "DIAG_CD_5":           {"type": "varchar(8)"},
        "DIAG_CD_6":           {"type": "varchar(8)"},
        "DIAG_CD_7":           {"type": "varchar(8)"},
        "DIAG_CD_8":           {"type": "varchar(8)"},
        "DIAG_CD_9":           {"type": "varchar(8)"}
      },
      "diag_columns": ["DIAG_CD_1","DIAG_CD_2","DIAG_CD_3","DIAG_CD_4","DIAG_CD_5","DIAG_CD_6","DIAG_CD_7","DIAG_CD_8","DIAG_CD_9"],
      "extraction_table": "Re_all_inpatient",
      "extraction_procedure": "Re_all_inpatient_loop"
