  "era_differences": {
    "_comment": "Key schema differences across the three eras — critical for correct SQL generation",
    "patient_id":    {"ERA1_ERA2": "patient_id (lowercase)", "TAF": "PATIENT_ID (uppercase)"},
    "year_column":   {"ERA1_ERA2": "YR_NUM",                 "TAF": "RFRNC_YR"},
    "dob_column":    {"ERA1_ERA2": "EL_DOB",                 "TAF": "BIRTH_DT"},
    "sex_column":    {"ERA1_ERA2": "EL_SEX_CD",              "TAF": "not available in claim table"},
    "race_column":   {"ERA1_ERA2": "EL_RACE_ETHNCY_CD",      "TAF": "not available in claim table"},
    "diag_prefix":   {"ERA1_ERA2": "DIAG_CD_",               "TAF": "DGNS_CD_"},
    "diag_count":    {"inpatient_ERA1_ERA2": 9,              "inpatient_TAF": 12, "outpatient_all": 2},
    "state_key_case":{"ERA1_ERA2": "state_key (lowercase)", "TAF": "STATE_KEY (uppercase)"}
  },

  "intermediate_tables": {
    "_comment": "Tables created by the pipeline steps. Not in cms_source — created in the working schema.",

    "Re_all_inpatient": {
      "created_by": "step1_extraction/Re_all_inpatient.sql",
      "source": "cms_source.inpatient",
      "columns": ["patient_id","BENE_ID","STATE_CD","state_key","YR_NUM","EL_DOB","EL_SEX_CD","EL_RACE_ETHNCY_CD","srvc_bgn_dt","srvc_end_dt","DIAG_CD_1..9"]
