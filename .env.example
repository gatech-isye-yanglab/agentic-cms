# Copy this file to .env and fill in your own values.
# Never commit .env to version control.

# Azure AI Foundry project endpoint
# Format: https://<resource-name>.services.ai.azure.com/api/projects/<project-name>
PROJECT_ENDPOINT=https://YOUR_RESOURCE.services.ai.azure.com/api/projects/YOUR_PROJECT

# Optional: agent name tag used in logging
AGENT_NAME=cms-agent
